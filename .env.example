# === Telegram (obligatorio) ===
# Obtén el token de @BotFather en Telegram
TELEGRAM_TOKEN=tu_token_aqui
# Chat ID de Telegram donde recibirás las alertas
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# === Ticketmaster API (opcional - si no se configura, usa solo scraping) ===
# Obtén una API key en https://developer.ticketmaster.com/
TICKETMASTER_API_KEY=tu_api_key_aqui
# ID del evento en Ticketmaster (ej: "Z7r9jZ1AdOk9Z")
TICKETMASTER_EVENT_ID=

# === OpenWA (WhatsApp - opcional) ===
# Servidor OpenWA (ver https://github.com/rmyndharis/OpenWA)
OPENWA_URL=http://localhost:2785/api
OPENWA_API_KEY=tu_api_key_openwa
# Número de teléfono por defecto en formato internacional +XXXXXXXXX@c.us
OPENWA_CHAT_ID=
# Nombre de la sesión de WhatsApp en OpenWA
OPENWA_SESSION=ticketmaster-bot

# === Multi-cliente ===
# Los clientes se configuran en clientes.json. Ahí definirás por cada uno:
# - nombre (para identificar en logs)
# - evento_id (ID del evento de Ticketmaster, o vacío para solo scraping)
# - url_scraping (URL para scraping, respaldo si no hay API)
# - telegram_chat_id (chat_id de Telegram para ese cliente)
# - whatsapp_chat_id (número WhatsApp para ese cliente, o vacío)
# - habilitado (true/false)
